# Environment variables (use .env.example for template)
docker/.env
.env
.env.local

# SSL/TLS certificates and keys (sensitive files)
ssl/certs/*.pem
ssl/certs/*.crt
ssl/certs/*.cer
ssl/keys/*.key
ssl/keys/*.pem
ssl/**/*.pem
ssl/**/*.key

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Editor files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Node modules (if using npm/webpack)
node_modules/
package-lock.json
yarn.lock

# Docker
.dockerignore

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp
